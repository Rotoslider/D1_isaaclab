<mujoco model="d1 mild terrain scene">
  <include file="d1.xml"/>

  <statistic center="0 0 0.1" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.25 0.3 0.25" rgb2="0.15 0.2 0.15"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="24 24" reflectance="0.1"/>
    <!-- 16x16 m gentle procedural roughness, max 15 cm high (Isaac-Lab-like random
         rough at low difficulty), flat 1.5 m pad at spawn -->
    <hfield name="mild_terrain" file="terrain_mild.png" size="8 8 0.15 0.02"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="hfield" hfield="mild_terrain" material="groundplane" friction="0.8 0.005 0.0001"/>
  </worldbody>
</mujoco>
